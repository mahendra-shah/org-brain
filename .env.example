# ==============================================================================
# OmniBrain Configuration Reference Template (.env.example)
# ==============================================================================

# LLM Selection
# Supported providers: "deepseek" or "claude" or "gemini"
LLM_PROVIDER=deepseek

# Toggle Developer Diagnostic Metadata Block in Chat Responses
# Set to "true" during local QA/development, "false" in production
SHOW_DEV_METADATA=true

# DeepSeek API Configuration
# standard url is: https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Claude API Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini API Configuration (OpenAI-compatible endpoint, also used for active automatic RAG fallbacks!)
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# Slack Socket Mode Configuration
# Copy this from api.slack.com -> Your App -> OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-
# Copy this from api.slack.com -> Your App -> Basic Information -> App-Level Tokens
SLACK_APP_TOKEN=xapp-

# Notion Workspace Integration Token
# Copy this from notion.so/my-integrations
NOTION_API_TOKEN=secret_
